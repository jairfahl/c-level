# Environment Variables Example
# Copy this file to .env and fill in the values

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cfo:cfo_password@localhost:5432/cfo_db"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Optional – if omitted the LLM layer returns structured mock data
OPENAI_API_KEY="sk-your-openai-api-key-here"

# ─── Admin Credentials (development only – use a proper users table in production) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed CORS origin for the frontend (backend only)
CORS_ORIGIN="http://localhost:3000"

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
